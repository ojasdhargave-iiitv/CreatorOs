# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Security (required)
# Used to sign the tokens that keep users logged in.
JWT_SECRET=run-this-command-'openssl rand -base64 32'-in-terminal-and-paste-the-output-here

# Database (required)
# Required to connect to your database. Without this, the app cannot store user accounts or persistent data.
DATABASE_URL=
MONGODB_URI=mongodb+srv://<user_name>:<password>@creatoros.7udof89w.mongodb.net/?appName=creatoros

# Instagram Graph API
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v25.0
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_LOOKUP_COOLDOWN_SECONDS=30

# AI Services
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Application Settings
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
